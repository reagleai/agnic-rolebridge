# ─────────────────────────────────────────────
# RoleBridge V1 — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Backend secrets are set in the Supabase dashboard (Edge Function secrets).
# Frontend vars are set in Vercel project settings.

# ── Backend (Supabase Edge Function secrets) ──
# Required:
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
GLADIA_API_KEY=
RESEND_API_KEY=
APP_URL=http://localhost:5173

# Optional: email sender (default: RoleBridge <reports@protonaiagents.com>)
# RESEND_FROM_EMAIL=RoleBridge <reports@protonaiagents.com>

# Optional LLM model overrides (defaults defined in _shared/llm.ts):
# LLM_MODEL_SECTION_EXTRACTION=google/gemini-2.0-flash-exp:free
# LLM_MODEL_QUESTION_GENERATION=google/gemini-2.0-flash-exp:free
# LLM_MODEL_ANSWER_EVALUATION=google/gemini-2.0-flash-exp:free
# LLM_MODEL_REPORT_GENERATION=qwen/qwen3-235b-a22b:free

# ── Frontend (Vite build-time, prefixed with VITE_) ──
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# ── Cron Setup (002_cron_setup.sql placeholders) ──
# These are NOT env vars — they are replaced directly in the SQL migration.
# SUPABASE_PROJECT_REF=<your-project-ref>
# SUPABASE_SERVICE_ROLE_KEY_FOR_CRON=<same as SERVICE_ROLE_KEY above>
