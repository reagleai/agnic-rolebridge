# ── Backend (Supabase Edge Function secrets) ──
# For local testing via `supabase functions serve`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
GLADIA_API_KEY=your_gladia_api_key_here
RESEND_API_KEY=your_resend_api_key_here
APP_URL=http://localhost:5174

# Optional: LLM model overrides (default: inclusionai/ling-2.6-1t:free)
# LLM_MODEL_SECTION_EXTRACTION=inclusionai/ling-2.6-1t:free
# LLM_MODEL_QUESTION_GENERATION=inclusionai/ling-2.6-1t:free
# LLM_MODEL_ANSWER_EVALUATION=inclusionai/ling-2.6-1t:free
# LLM_MODEL_REPORT_GENERATION=inclusionai/ling-2.6-1t:free

# ── V2: Agnic OAuth + Partner Program ──
# Set these after registering at app.agnic.ai/oauth-clients
AGNIC_CLIENT_ID=your_agnic_client_id_here
AGNIC_CLIENT_SECRET=your_agnic_client_secret_here
AGNIC_PARTNER_ID=
RB_SESSION_SECRET=generate_a_random_secret_string_here
